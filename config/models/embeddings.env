MODEL_KEY=embeddings
MODEL_DISPLAY_NAME=Qwen/Qwen3-Embedding-0.6B
MODEL_ROLE=embedding
MODEL_SOURCE_REPO=Qwen/Qwen3-Embedding-0.6B
MODEL_REPO=Qwen/Qwen3-Embedding-0.6B-GGUF
MODEL_FILENAME=Qwen3-Embedding-0.6B-Q8_0.gguf
MODEL_INCLUDE_PATTERN=Qwen3-Embedding-0.6B-Q8_0.gguf
MODEL_REVISION=main
MODEL_DIR=${PROJECT_ROOT}/models/embeddings
MODEL_FILE=${MODEL_DIR}/${MODEL_FILENAME}
MODEL_ALLOWED_DEVICES=cpu,gpu
MODEL_DEVICE=gpu
MODEL_HOST=127.0.0.1
MODEL_PORT=8101
SERVER_MODE=embedding
POOLING=last
# Per-slot context = CONTEXT_SIZE / PARALLEL. Dense code chunks up to ~2k
# tokens were previously rejected with "request exceeds available context
# size (2048 tokens)" when CONTEXT_SIZE=8192 and PARALLEL=4 (8192/4=2048
# per slot). 16384/2 = 8192 per slot fits any chunk while keeping two
# concurrent embedding tasks.
CONTEXT_SIZE=16384
THREADS=12
PARALLEL=2
CPU_BATCH=2048
CPU_UBATCH=512
GPU_BATCH=2048
GPU_UBATCH=512
GPU_LAYERS=99
CPU_EXTRA_ARGS=
GPU_EXTRA_ARGS=
SERVER_EXTRA_ARGS=
LORA_ENABLED=false

