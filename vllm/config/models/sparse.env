MODEL_KEY=sparse
MODEL_DISPLAY_NAME=HuggingFaceTB/SmolLM2-1.7B-Instruct
MODEL_ROLE=sparse
MODEL_SOURCE_REPO=HuggingFaceTB/SmolLM2-1.7B-Instruct
MODEL_REPO=HuggingFaceTB/SmolLM2-1.7B-Instruct
MODEL_ENTRYPOINT=config.json
MODEL_INCLUDE_PATTERN=*.json,**/*.json,*.safetensors,**/*.safetensors,*.model,**/*.model,tokenizer*,**/tokenizer*,vocab*,**/vocab*,merges.txt,**/merges.txt,*.py,**/*.py
MODEL_REVISION=main
MODEL_DIR=${PROJECT_ROOT}/models/sparse
MODEL_PATH=${MODEL_DIR}
MODEL_ALLOWED_DEVICES=cpu,gpu
MODEL_DEVICE=gpu
MODEL_HOST=127.0.0.1
MODEL_PORT=8103
SERVER_TASK=generate
CONTEXT_SIZE=3584
THREADS=12
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.75
SWAP_SPACE=3
MAX_NUM_SEQS=8
MAX_NUM_BATCHED_TOKENS=4096
DTYPE=auto
QUANTIZATION=
TRUST_REMOTE_CODE=false
ENABLE_PREFIX_CACHING=true
CPU_KV_CACHE_GB=8
CPU_EXTRA_ARGS=
GPU_EXTRA_ARGS=
SERVER_EXTRA_ARGS=
SERVER_API_KEY=
CHAT_TEMPLATE=
LORA_ENABLED=false
