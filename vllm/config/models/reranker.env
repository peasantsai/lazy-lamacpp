MODEL_KEY=reranker
MODEL_DISPLAY_NAME=BAAI/bge-reranker-v2-m3
MODEL_ROLE=reranker
MODEL_SOURCE_REPO=BAAI/bge-reranker-v2-m3
MODEL_REPO=BAAI/bge-reranker-v2-m3
MODEL_ENTRYPOINT=config.json
MODEL_INCLUDE_PATTERN=*.json,**/*.json,*.safetensors,**/*.safetensors,*.model,**/*.model,tokenizer*,**/tokenizer*,vocab*,**/vocab*,merges.txt,**/merges.txt,*.py,**/*.py
MODEL_REVISION=main
MODEL_DIR=${PROJECT_ROOT}/models/reranker
MODEL_PATH=${MODEL_DIR}
MODEL_ALLOWED_DEVICES=cpu,gpu
MODEL_DEVICE=gpu
MODEL_HOST=127.0.0.1
MODEL_PORT=8104
SERVER_TASK=score
CONTEXT_SIZE=8192
THREADS=12
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.55
SWAP_SPACE=2
MAX_NUM_SEQS=32
MAX_NUM_BATCHED_TOKENS=8192
DTYPE=auto
QUANTIZATION=
TRUST_REMOTE_CODE=false
ENABLE_PREFIX_CACHING=false
CPU_KV_CACHE_GB=8
CPU_EXTRA_ARGS=
GPU_EXTRA_ARGS=
SERVER_EXTRA_ARGS=
SERVER_API_KEY=
CHAT_TEMPLATE=
LORA_ENABLED=false
