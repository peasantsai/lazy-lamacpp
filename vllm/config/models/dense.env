MODEL_KEY=dense
MODEL_DISPLAY_NAME=Qwen/Qwen2.5-3B-Instruct-AWQ
MODEL_ROLE=dense
MODEL_SOURCE_REPO=Qwen/Qwen2.5-3B-Instruct-AWQ
MODEL_REPO=Qwen/Qwen2.5-3B-Instruct-AWQ
MODEL_ENTRYPOINT=config.json
MODEL_INCLUDE_PATTERN=*.json,**/*.json,*.safetensors,**/*.safetensors,*.model,**/*.model,tokenizer*,**/tokenizer*,vocab*,**/vocab*,merges.txt,**/merges.txt,*.py,**/*.py
MODEL_REVISION=main
MODEL_DIR=${PROJECT_ROOT}/models/dense
MODEL_PATH=${MODEL_DIR}
MODEL_ALLOWED_DEVICES=gpu
MODEL_DEVICE=gpu
MODEL_HOST=127.0.0.1
MODEL_PORT=8102
SERVER_TASK=generate
CONTEXT_SIZE=8192
THREADS=12
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.70
SWAP_SPACE=4
MAX_NUM_SEQS=4
MAX_NUM_BATCHED_TOKENS=4096
DTYPE=half
QUANTIZATION=awq_marlin
TRUST_REMOTE_CODE=false
ENABLE_PREFIX_CACHING=true
CPU_KV_CACHE_GB=4
CPU_EXTRA_ARGS=
GPU_EXTRA_ARGS=
SERVER_EXTRA_ARGS=
SERVER_API_KEY=
CHAT_TEMPLATE=
LORA_ENABLED=true
LORA_MANIFEST=${PROJECT_ROOT}/config/loras/dense.env
LORA_MAX_COUNT=4
LORA_MAX_CPU_COUNT=8
LORA_MAX_RANK=64
